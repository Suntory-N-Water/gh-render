{
  "name": "gh-render",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "deploy": "wrangler deploy --minify",
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview",
    "start": "wrangler dev --test-scheduled",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply github-trending-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply github-trending-db --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:ai": "set -o pipefail && biome lint . --reporter=github 2>&1 | { grep '^::' || true; }",
    "lint:fix": "biome lint --write .",
    "lint:unsafe-fix": "biome lint --write --unsafe .",
    "type-check": "tsc -b",
    "type-check:ai": "tsc -b 2>&1",
    "test": "AGENT=1 vitest run",
    "test:coverage": "AGENT=1 vitest run --coverage",
    "ai-check": "bun run format && bun run lint:ai && bun run type-check:ai",
    "knip": "knip"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@cloudflare/vite-plugin": "^1.36.3",
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "knip": "^6.12.2",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typed-query-selector": "^2.12.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
